-> Mediator design pattern 
    if we follow the same analogy as subscriber pattern if the type of subscriber is same but the channel that we have start having diff mediators that have different 
    implementations to provide text with a common mediator interface, similarly a more suitable example would be bidder and mediator ones.

    class Bidder{
        private AuctionMediator mediator;
        void placeBid(Integer bid){
            mediator.placeBid(this,bid);
        }
        string receiveBid(Integer bidAmount){
            return "bid amount is"+bidAmount;
        }
    }

    interface Mediator{
        public void addBidder(Bidder bidder);
        public void PlaceBid(Bidder bidder,Integer bid);
    }

    class AuctionMediator implement Mediator{
        private List<Bidder> bidders = new ArrayList<>();

        public void addBidder(Bidder bidder){
            bidders.add(bidder);
        }

        public void placeBid(Bidder bidder,Integer bid){
            for(Bidder b: bidders){
                if(b != bidder){
                    b.receiveBid(bid);
                }
            }
        }

    } 

    class NewAuctionMediator extends AuctionMediator{
        //add new functionality and use directly makes code modular
    }

-> state design pattern
    when we have states and we want to keep the logic seperate for them and make the transition smooth

    class stateContext {
        public State current;
        public stateContext(){
            this.current = new redState();
        }
        public setState(State s){
            this.current = s;
        }
        public nextState(){
            return current.moveToNext(this);
        }
    }

    interface State{
        string getColor();
        void moveToNext(stateContext context);
    }

    class redState implement State{
        string color = "red";

        string getColor(){
            return this.color;
        }
        public moveToNext(stateContext context){
            context.current = new greenState();
        }
    }

