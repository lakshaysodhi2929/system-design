-> momento(snapshot) design pattern - when we want to save last state, like when multiple people are working on common resource so modifiing that is not a good idea instead
having a copy of it for every one is better.

    class textEditor{
        string text;
        public void setText(string t){
            text = t;
        }

        public void saveText(){
            return new Momento(text);
        }

        public void restore(Momento m){
            this.text = m.getText();
        }
    }

    class TextManager{
        public stack<Momento> history = new stack<>();
        public void push(Momento m){
            history.push(m);
        }
        public Momento pop(){
            if(!history.empty()){
                return history.pop();
            }
            return null;
        }
    }

    public Momento {
        private final string text;
        public Momento(string text){
            this.text = text;
        }
        public getText(){
            return text;
        }
    }

